node_modules/
.DS_Store

# Runtime outputs
current/
diff/
normalized/
reports/
input/
analysis_outputs/

# Python env
.venv/

# Keep folder placeholders
!current/.gitkeep
!diff/.gitkeep
!normalized/.gitkeep
!reports/.gitkeep
!input/.gitkeep

# Allow example artifacts
!examples/**/current/
!examples/**/current/*.png
!examples/**/diff/
!examples/**/diff/*.png

# Optional generated sources
generated/*.html
generated/*.css
target/*.png
